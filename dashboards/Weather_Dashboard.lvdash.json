{
  "datasets": [
    {
      "name": "ae550655",
      "displayName": "Chloropeth map",
      "queryLines": [
        "SELECT \n",
        "  country,\n",
        "  ROUND(AVG(temperature_c), 1) AS avg_temp_c,\n",
        "  COUNT(DISTINCT city) AS num_cities,\n",
        "  ROUND(AVG(humidity_pct), 1) AS avg_humidity_pct\n",
        "FROM weather_gold_city_ranking\n",
        "GROUP BY country\n"
      ]
    },
    {
      "name": "bef8d385",
      "displayName": "Hottest city",
      "queryLines": [
        "SELECT city, temperature_c FROM weather_gold_city_ranking WHERE temp_rank = 1"
      ]
    },
    {
      "name": "92a32ef7",
      "displayName": "Coldest City",
      "queryLines": [
        "SELECT city, temperature_c FROM weather_gold_city_ranking ORDER BY temp_rank DESC LIMIT 1"
      ]
    },
    {
      "name": "a74639a1",
      "displayName": "Rainiest City",
      "queryLines": [
        "SELECT city, total_precipitation_mm FROM weather_gold_daily ORDER BY total_precipitation_mm DESC LIMIT 1"
      ]
    },
    {
      "name": "3029e88a",
      "displayName": "Windiest City",
      "queryLines": [
        "SELECT city, wind_speed_kmh FROM weather_gold_city_ranking ORDER BY wind_speed_kmh DESC LIMIT 1\n"
      ]
    },
    {
      "name": "93dde377",
      "displayName": "Hot vs Cold",
      "queryLines": [
        "SELECT city, temperature_c,\n",
        "  CASE WHEN temperature_c >= 25 THEN 'Hot'\n",
        "       WHEN temperature_c >= 15 THEN 'Warm'\n",
        "       WHEN temperature_c >= 5  THEN 'Cool'\n",
        "       ELSE 'Cold'\n",
        "  END AS category\n",
        "FROM weather_gold_city_ranking\n",
        "ORDER BY temperature_c DESC"
      ]
    },
    {
      "name": "2817cc2b",
      "displayName": "Weather Condition Breakdown",
      "queryLines": [
        "SELECT weather_description, COUNT(*) as city_count\n",
        "FROM weather_gold_city_ranking\n",
        "GROUP BY weather_description\n",
        "ORDER BY city_count DESC"
      ]
    },
    {
      "name": "1a186b70",
      "displayName": "Wind Speed vs Temperature",
      "queryLines": [
        "SELECT city, temperature_c, wind_speed_kmh, humidity_pct\n",
        "FROM weather_gold_city_ranking\n"
      ]
    }
  ],
