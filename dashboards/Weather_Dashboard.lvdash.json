{
  "datasets": [
    {
      "name": "ae550655",
      "displayName": "Chloropeth map",
      "queryLines": [
        "SELECT \n",
        "  country,\n",
        "  ROUND(AVG(temperature_c), 1) AS avg_temp_c,\n",
        "  COUNT(DISTINCT city) AS num_cities,\n",
        "  ROUND(AVG(humidity_pct), 1) AS avg_humidity_pct\n",
        "FROM weather_gold_city_ranking\n",
        "GROUP BY country\n"
      ]
    },
    {
      "name": "bef8d385",
      "displayName": "Hottest city",
      "queryLines": [
        "SELECT city, temperature_c FROM weather_gold_city_ranking WHERE temp_rank = 1"
      ]
    },
    {
      "name": "92a32ef7",
      "displayName": "Coldest City",
      "queryLines": [
        "SELECT city, temperature_c FROM weather_gold_city_ranking ORDER BY temp_rank DESC LIMIT 1"
      ]
    },
    {
      "name": "a74639a1",
      "displayName": "Rainiest City",
      "queryLines": [
        "SELECT city, total_precipitation_mm FROM weather_gold_daily ORDER BY total_precipitation_mm DESC LIMIT 1"
      ]
    },
    {
      "name": "3029e88a",
      "displayName": "Windiest City",
      "queryLines": [
        "SELECT city, wind_speed_kmh FROM weather_gold_city_ranking ORDER BY wind_speed_kmh DESC LIMIT 1\n"
      ]
    },
    {
      "name": "93dde377",
      "displayName": "Hot vs Cold",
      "queryLines": [
        "SELECT city, temperature_c,\n",
        "  CASE WHEN temperature_c >= 25 THEN 'Hot'\n",
        "       WHEN temperature_c >= 15 THEN 'Warm'\n",
        "       WHEN temperature_c >= 5  THEN 'Cool'\n",
        "       ELSE 'Cold'\n",
        "  END AS category\n",
        "FROM weather_gold_city_ranking\n",
        "ORDER BY temperature_c DESC"
      ]
    },
    {
      "name": "2817cc2b",
      "displayName": "Weather Condition Breakdown",
      "queryLines": [
        "SELECT weather_description, COUNT(*) as city_count\n",
        "FROM weather_gold_city_ranking\n",
        "GROUP BY weather_description\n",
        "ORDER BY city_count DESC"
      ]
    },
    {
      "name": "1a186b70",
      "displayName": "Wind Speed vs Temperature",
      "queryLines": [
        "SELECT city, temperature_c, wind_speed_kmh, humidity_pct\n",
        "FROM weather_gold_city_ranking\n"
      ]
    },
    {
      "name": "1b9b5f3e",
      "displayName": "Global Monthly Climate Averages Summary",
      "queryLines": [
        "SELECT\n",
        "    DATE_TRUNC('month', date)          AS month,\n",
        "    ROUND(AVG(avg_temp_c), 1)          AS global_avg_temp_c,\n",
        "    ROUND(AVG(avg_humidity_pct), 1)    AS global_avg_humidity_pct,\n",
        "    ROUND(AVG(total_precipitation_mm), 1) AS global_avg_precip_mm\n",
        "FROM weather_gold_daily\n",
        "GROUP BY 1\n",
        "ORDER BY 1"
      ]
    },
    {
      "name": "54836373",
      "displayName": "city_details_table",
      "queryLines": [
        "SELECT\n",
        "  temp_rank,\n",
        "  city,\n",
        "  country,\n",
        "  temperature_c,\n",
        "  feels_like_c,\n",
        "  ROUND(feels_like_c - temperature_c, 1) AS feels_diff_c,\n",
        "  humidity_pct,\n",
        "  wind_speed_kmh,\n",
        "  precipitation_mm,\n",
        "  weather_description,\n",
        "  DATE_FORMAT(time, 'HH:mm:ss') AS local_time\n",
        "FROM\n",
        "  weather_gold_city_ranking\n",
        "ORDER BY\n",
        "  temp_rank"
      ]
    },
    {
      "name": "b483b928",
      "displayName": "Temperature Anamolies",
      "queryLines": [
        "SELECT\n",
        "    city, country, date,\n",
        "    today_temp_c, normal_temp_c,\n",
        "    ROUND(today_temp_c - normal_temp_c, 1) AS temp_deviation_c,\n",
        "    zscore_temp, anomaly_type, severity, detected_at, today_wind_kmh, today_precip_mm\n",
        "FROM weather_gold_anomalies\n",
        "ORDER BY ABS(zscore_temp) DESC\n"
      ]
    },
    {
      "name": "0946cce0",
      "displayName": "city_climate_clusters",
      "queryLines": [
        "SELECT\n",
        "    city,\n",
        "    country,\n",
        "    climate_cluster,\n",
        "    mean_temp_c,\n",
        "    mean_humidity,\n",
        "    mean_wind_kmh,\n",
        "    mean_precip_mm\n",
        "FROM weather_gold_city_clusters\n",
        "ORDER BY climate_cluster, mean_temp_c DESC"
      ]
    },
    {
      "name": "cf52d490",
      "displayName": "cluster_summary",
      "queryLines": [
        "SELECT\n",
        "    climate_cluster,\n",
        "    COUNT(*)                          AS city_count,\n",
        "    ROUND(AVG(mean_temp_c), 1)        AS avg_temp_c,\n",
        "    ROUND(AVG(mean_humidity), 1)      AS avg_humidity_pct,\n",
        "    ROUND(AVG(mean_wind_kmh), 1)      AS avg_wind_kmh,\n",
        "    ROUND(AVG(mean_precip_mm), 1)     AS avg_precip_mm\n",
        "FROM weather_gold_city_clusters\n",
        "GROUP BY climate_cluster\n",
        "ORDER BY avg_temp_c DESC"
      ]
    },
    {
      "name": "71e290d7",
      "displayName": "Forecasts",
      "queryLines": [
        "SELECT\n",
        "    city,\n",
        "    country,\n",
        "    DATE(forecast_date)                               AS forecast_date,\n",
        "    predicted_temp_c,\n",
        "    predicted_low_c,\n",
        "    predicted_high_c,\n",
        "    ROUND(predicted_high_c - predicted_low_c, 1)      AS uncertainty_c\n",
        "FROM weather_gold_forecast\n",
        "ORDER BY city, forecast_date"
      ]
    }
  ],
